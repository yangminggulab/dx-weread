page{background-color:#f7f5f0;color:#1c1c1c;font-family:-apple-system,PingFang SC,Helvetica Neue,sans-serif}.card{background:#fff;border-radius:12rpx;-webkit-box-shadow:0 1rpx 6rpx rgba(0,0,0,.06);box-shadow:0 1rpx 6rpx rgba(0,0,0,.06);margin-bottom:20rpx;padding:28rpx}.tag{border-radius:20rpx;display:inline-block;font-size:22rpx;margin-bottom:8rpx;margin-right:10rpx;padding:4rpx 16rpx}.priority-high{background:#fdf0ef;color:#c0392b}.priority-medium{background:#fef9ec;color:#d47a00}.priority-low{background:#eef5f1;color:#3a7d52}.status-todo{background:#f2f2f2;color:#888}.status-in_progress{background:#eaf2fb;color:#1e6db8}.status-completed{background:#eef5f1;color:#3a7d52}.empty{color:#aaa;font-size:28rpx;padding:80rpx 0;text-align:center}.divider{background:#f0ede8;height:1rpx;margin:16rpx 0}