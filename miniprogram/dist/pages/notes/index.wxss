.notes-page{background:#f7f5f0;height:100vh;overflow:hidden;padding-bottom:120rpx}.page-header{background:#2d6a4f;padding:40rpx 32rpx 20rpx}.page-title{color:#fff;display:block;font-size:44rpx;font-weight:700;margin-bottom:8rpx}.page-subtitle{color:hsla(0,0%,100%,.7);font-size:26rpx}.search-bar{-ms-flex-align:center;-webkit-align-items:center;align-items:center;background:#fff;border-radius:50rpx;-webkit-box-shadow:0 1rpx 6rpx rgba(0,0,0,.06);box-shadow:0 1rpx 6rpx rgba(0,0,0,.06);display:-webkit-flex;display:-ms-flexbox;display:flex;margin:20rpx 24rpx;padding:16rpx 24rpx}.search-icon{font-size:28rpx;margin-right:12rpx}.search-input{background:transparent;border:none;color:#1c1c1c;-webkit-flex:1;-ms-flex:1;flex:1;font-size:28rpx}.search-clear{color:#aaa;font-size:28rpx;padding:0 8rpx}.notes-list{height:calc(100vh - 300rpx);overflow:hidden;width:100%}.note-card{margin-left:24rpx;margin-right:24rpx}.note-header{-ms-flex-pack:justify;-ms-flex-align:start;-webkit-align-items:flex-start;align-items:flex-start;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-justify-content:space-between;justify-content:space-between;margin-bottom:14rpx}.note-title{color:#1c1c1c;-webkit-flex:1;-ms-flex:1;flex:1;font-size:30rpx;font-weight:600;line-height:1.4;margin-right:20rpx}.note-date{color:#aaa;font-size:22rpx;margin-top:4rpx;white-space:nowrap}.note-summary{color:#666;font-size:26rpx;line-height:1.6;margin-bottom:16rpx}.note-footer{-ms-flex-align:end;-ms-flex-pack:justify;-webkit-align-items:flex-end;align-items:flex-end;display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-justify-content:space-between;justify-content:space-between}.note-tags{display:-webkit-flex;display:-ms-flexbox;display:flex;-webkit-flex:1;-ms-flex:1;flex:1;-webkit-flex-wrap:wrap;-ms-flex-wrap:wrap;flex-wrap:wrap}.note-tag{background:#eef5f1;border-radius:20rpx;color:#3a7d52;font-size:22rpx;margin-bottom:6rpx;margin-right:10rpx;padding:4rpx 14rpx}.empty{color:#aaa;font-size:28rpx;padding:80rpx 0;text-align:center}.fab{-ms-flex-align:center;-ms-flex-pack:center;-webkit-align-items:center;align-items:center;background:#2d6a4f;border-radius:50%;bottom:160rpx;-webkit-box-shadow:0 4rpx 16rpx rgba(45,106,79,.4);box-shadow:0 4rpx 16rpx rgba(45,106,79,.4);display:-webkit-flex;display:-ms-flexbox;display:flex;height:100rpx;-webkit-justify-content:center;justify-content:center;position:fixed;right:40rpx;width:100rpx;z-index:100}.fab-icon{color:#fff;font-size:56rpx;line-height:1;margin-top:-4rpx}.modal-mask{-ms-flex-align:end;-webkit-align-items:flex-end;align-items:flex-end;background:rgba(0,0,0,.4);bottom:0;display:-webkit-flex;display:-ms-flexbox;display:flex;left:0;position:fixed;right:0;top:0;z-index:200}.modal-box{background:#fff;border-radius:24rpx 24rpx 0 0;padding:40rpx 32rpx 60rpx;width:100%}.modal-title{color:#1c1c1c;display:block;font-size:34rpx;font-weight:600;margin-bottom:36rpx}.form-item{margin-bottom:28rpx}.form-label{color:#666;display:block;font-size:26rpx;margin-bottom:12rpx}.form-input{background:#fafaf8;border:1.5rpx solid #e8e0d4;border-radius:12rpx;-webkit-box-sizing:border-box;box-sizing:border-box;font-size:28rpx;padding:20rpx 24rpx;width:100%}.form-textarea{background:#fafaf8;border:1.5rpx solid #e8e0d4;border-radius:12rpx;-webkit-box-sizing:border-box;box-sizing:border-box;font-size:28rpx;line-height:1.6;min-height:160rpx;padding:20rpx 24rpx;width:100%}.modal-actions{display:-webkit-flex;display:-ms-flexbox;display:flex;margin-top:40rpx}.btn-cancel,.btn-confirm{border-radius:14rpx;-webkit-flex:1;-ms-flex:1;flex:1;font-size:30rpx;font-weight:600;padding:28rpx 0;text-align:center}.btn-cancel{background:#f5f5f5;color:#666;margin-right:20rpx}.btn-confirm{background:#2d6a4f;color:#fff}.diary-tag{background:#eef3ff;border:1rpx solid #c8d8f0;border-radius:8rpx;color:#4a6fa5;font-size:22rpx;padding:2rpx 12rpx}.section-divider{margin:20rpx 0 8rpx}.section-divider-text{color:#aaa;font-size:24rpx}